# RAG Job Search Agent - Environment Variables
# Copy this to .env and fill in your keys

# Required: Get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Get from https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Only needed for live job search. You can also upload jobs via CSV.
JSEARCH_API_KEY=your_jsearch_api_key_here
